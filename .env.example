# GitHub OAuth configuration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Database connection
DATABASE_URL=postgresql://username:password@localhost:5432/graphify

# Frontend URL for CORS
FRONTEND_URL=http://localhost:4200

# JWT Secret for authentication
JWT_SECRET=your_secure_jwt_secret
JWT_EXPIRATION=24h

# CLI Encryption Key - IMPORTANT: use a strong unique key in production
GRAPHIFY_ENCRYPTION_KEY=your_secure_encryption_key

# Vercel deployment settings for GitHub Actions
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_ID=your_vercel_project_id
