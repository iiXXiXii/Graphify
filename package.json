{
  "name": "graphify",
  "version": "1.1.0",
  "description": "GitHub contribution graph generator with TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "graphify": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/app.ts",
    "start": "node dist/index.js",
    "watch": "tsc -w",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "npm run build",
    "postinstall": "node -e \"try { require('fs').chmodSync('./dist/index.js', '755') } catch (e) {}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docs": "typedoc --out docs src",
    "analyze": "graphify analyze",
    "validate": "graphify validate",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/iiXXiXii/Graphify"
  },
  "keywords": [
    "github",
    "graph",
    "contribution",
    "typescript",
    "git",
    "commits",
    "pattern"
  ],
  "author": "iiXXiXii",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^19.0.13",
    "axios": "^1.6.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "conf": "^11.0.2",
    "figlet": "^1.7.0",
    "inquirer": "^8.2.6",
    "jsonfile": "^6.1.0",
    "log-symbols": "^4.1.0",
    "luxon": "^3.4.4",
    "ora": "^5.4.1",
    "simple-git": "^3.22.0",
    "terminal-link": "^2.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/inquirer": "^8.2.6",
    "@types/jest": "^29.5.10",
    "@types/jsonfile": "^6.1.4",
    "@types/luxon": "^3.3.7",
    "@types/node": "^20.10.1",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typedoc": "^0.25.3",
    "typescript": "^5.3.2"
  }
}
