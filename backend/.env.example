# Environment Configuration for Graphify

# GitHub OAuth App Credentials
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/v1/auth/github/callback

# Database Connection URL
DATABASE_URL="postgresql://postgres:password@localhost:5432/graphify?schema=public"

# Frontend URL for CORS
FRONTEND_URL=http://localhost:4200

# JWT Secret for authentication
JWT_SECRET=your-jwt-secret-key-should-be-long-and-secure
JWT_EXPIRATION=7d

# CLI Encryption Key
GRAPHIFY_ENCRYPTION_KEY=<your-secure-encryption-key>

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200
